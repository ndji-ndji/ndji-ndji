# URL et clé publique anonyme de Supabase (exposés côté client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé de rôle de service Supabase (ATTENTION: NE JAMAIS EXPOSER CÔTÉ CLIENT, uniquement côté serveur dans API Routes)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL publique de l'application (pour les redirections et métadonnées PWA)
NEXT_PUBLIC_APP_URL=http://localhost:3000
